<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
    <file source-language="en" target-language="en" datatype="plaintext" original="messages.en.xlf">
        <body>
            <trans-unit id="gps.tracking" resname="gps.tracking">
                <source>gps.tracking</source>
                <target>GPS Tracking</target>
            </trans-unit>
            <trans-unit id="gps.tracking_enabled" resname="gps.tracking_enabled">
                <source>gps.tracking_enabled</source>
                <target>Enable GPS Tracking</target>
            </trans-unit>
            <trans-unit id="gps.tracking_enabled.help" resname="gps.tracking_enabled.help">
                <source>gps.tracking_enabled.help</source>
                <target>Enable GPS location tracking for timesheet entries (global setting)</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking_enabled" resname="gps.user_tracking_enabled">
                <source>gps.user_tracking_enabled</source>
                <target>GPS Tracking Enabled</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking_enabled.help" resname="gps.user_tracking_enabled.help">
                <source>gps.user_tracking_enabled.help</source>
                <target>Allow GPS tracking for this user (requires global setting enabled)</target>
            </trans-unit>
            <trans-unit id="gps_edit_user_preference" resname="gps_edit_user_preference">
                <source>gps_edit_user_preference</source>
                <target>Edit user GPS tracking preference</target>
            </trans-unit>
            <trans-unit id="gps_view_data" resname="gps_view_data">
                <source>gps_view_data</source>
                <target>View GPS location data</target>
            </trans-unit>
            <trans-unit id="gps_edit_data" resname="gps_edit_data">
                <source>gps_edit_data</source>
                <target>Edit GPS location data</target>
            </trans-unit>
            <trans-unit id="gps.start_location" resname="gps.start_location">
                <source>gps.start_location</source>
                <target>GPS Start Location</target>
            </trans-unit>
            <trans-unit id="gps.stop_location" resname="gps.stop_location">
                <source>gps.stop_location</source>
                <target>GPS Stop Location</target>
            </trans-unit>
            <trans-unit id="gps.coordinate_format_invalid" resname="gps.coordinate_format_invalid">
                <source>gps.coordinate_format_invalid</source>
                <target>Invalid GPS format. Expected: "latitude,longitude"</target>
            </trans-unit>
            <trans-unit id="gps.map.title" resname="gps.map.title">
                <source>gps.map.title</source>
                <target>GPS Location Map</target>
            </trans-unit>
            <trans-unit id="gps.map.start_marker" resname="gps.map.start_marker">
                <source>gps.map.start_marker</source>
                <target>Start Location</target>
            </trans-unit>
            <trans-unit id="gps.map.stop_marker" resname="gps.map.stop_marker">
                <source>gps.map.stop_marker</source>
                <target>Stop Location</target>
            </trans-unit>
            <trans-unit id="gps.map.no_data" resname="gps.map.no_data">
                <source>gps.map.no_data</source>
                <target>No GPS data available</target>
            </trans-unit>
            <trans-unit id="gps.map.load_error" resname="gps.map.load_error">
                <source>gps.map.load_error</source>
                <target>Map could not be loaded</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking.help.explanation" resname="gps.user_tracking.help.explanation">
                <source>gps.user_tracking.help.explanation</source>
                <target>GPS tracking requires both global and user settings enabled.</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking.effective_status" resname="gps.user_tracking.effective_status">
                <source>gps.user_tracking.effective_status</source>
                <target>Effective status</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking.status.active" resname="gps.user_tracking.status.active">
                <source>gps.user_tracking.status.active</source>
                <target>Active</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking.status.inactive" resname="gps.user_tracking.status.inactive">
                <source>gps.user_tracking.status.inactive</source>
                <target>Inactive</target>
            </trans-unit>
            <trans-unit id="gps.user_tracking.status.global_disabled" resname="gps.user_tracking.status.global_disabled">
                <source>gps.user_tracking.status.global_disabled</source>
                <target>(global tracking is disabled)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_enabled" resname="gps.geofence_enabled">
                <source>gps.geofence_enabled</source>
                <target>Enable Geofence Boundary</target>
            </trans-unit>
            <trans-unit id="gps.geofence_enabled.help" resname="gps.geofence_enabled.help">
                <source>gps.geofence_enabled.help</source>
                <target>Enable workplace boundary checking to notify users when outside defined area</target>
            </trans-unit>
            <trans-unit id="gps.geofence_center_lat" resname="gps.geofence_center_lat">
                <source>gps.geofence_center_lat</source>
                <target>Center Latitude</target>
            </trans-unit>
            <trans-unit id="gps.geofence_center_lat.help" resname="gps.geofence_center_lat.help">
                <source>gps.geofence_center_lat.help</source>
                <target>Latitude of geofence center point in decimal degrees (-90 to 90)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_center_lng" resname="gps.geofence_center_lng">
                <source>gps.geofence_center_lng</source>
                <target>Center Longitude</target>
            </trans-unit>
            <trans-unit id="gps.geofence_center_lng.help" resname="gps.geofence_center_lng.help">
                <source>gps.geofence_center_lng.help</source>
                <target>Longitude of geofence center point in decimal degrees (-180 to 180)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_radius" resname="gps.geofence_radius">
                <source>gps.geofence_radius</source>
                <target>Radius (meters)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_radius.help" resname="gps.geofence_radius.help">
                <source>gps.geofence_radius.help</source>
                <target>Boundary radius around center point in meters (10-1000)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_notify_after" resname="gps.geofence_notify_after">
                <source>gps.geofence_notify_after</source>
                <target>Notify After (minutes)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_notify_after.help" resname="gps.geofence_notify_after.help">
                <source>gps.geofence_notify_after.help</source>
                <target>Minutes user must stay inside boundary before notification triggers (0=immediate, max 60)</target>
            </trans-unit>
            <trans-unit id="gps.geofence_restrict_mobile_tracking" resname="gps.geofence_restrict_mobile_tracking">
                <source>gps.geofence_restrict_mobile_tracking</source>
                <target>Restrict Mobile Tracking</target>
            </trans-unit>
            <trans-unit id="gps.geofence_restrict_mobile_tracking.help" resname="gps.geofence_restrict_mobile_tracking.help">
                <source>gps.geofence_restrict_mobile_tracking.help</source>
                <target>Prevent mobile users from starting time tracking outside the geofence boundary</target>
            </trans-unit>
        </body>
    </file>
</xliff>
